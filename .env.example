# ── Oura ──────────────────────────────────────────────────────────────────────
# Génère ton token sur : https://cloud.ouraring.com/personal-access-tokens
OURA_TOKEN=ton_token_ici

# ── Snowflake ──────────────────────────────────────────────────────────────────
# Identifiant de compte : trouve-le dans Snowflake → Admin → Accounts
# Format AWS  : xy12345.us-east-1
# Format Azure: xy12345.east-us-2.azure
# Format GCP  : xy12345.us-central1.gcp
# Format Org  : monorg-moncompte
SF_ACCOUNT=xy12345.us-east-1

SF_USER=mon_utilisateur
SF_PASSWORD=mon_mot_de_passe
SF_WAREHOUSE=COMPUTE_WH
SF_DATABASE=MA_BASE

# Optionnel (défaut : OURA)
SF_SCHEMA=OURA

# Optionnel : laisse vide si pas de rôle spécifique
SF_ROLE=
